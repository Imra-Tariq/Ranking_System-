def update_bps(bps_val):
    le = all_events[all_events["bps_level"]==bps_val].copy()
    ef = go.Figure(); ef.update_layout(**CHART_BASE)
    if le.empty:
        ef.update_layout(annotations=[dict(text=f"No data for BPS {bps_val}",showarrow=False,
                                           font=dict(color=P["muted"],size=14))])
        return ef,ef,[dbc.Badge(f"0 Members",color="secondary",className="me-2 fs-6")],\
               dbc.Badge("No data",color="secondary",className="fs-6"),\
               html.Div("No records.",style={"color":P["muted"],"padding":"12px"}),ef,\
               html.Div("No records.",style={"color":P["muted"],"padding":"12px"})

    le2  = le.groupby("ArfNo")["event_date"].min().reset_index(name="level_date")
    df   = le2.merge(report, on="ArfNo", how="left").sort_values("seniority_rank").copy()
    df["ld_fmt"]  = df["level_date"].dt.strftime("%d-%b-%Y")
    df["is_peak"] = df["highest_bps"]==bps_val
    evts = le.merge(df[["ArfNo","seniority_rank"]],on="ArfNo")
    tc   = (df.groupby("ld_fmt")["ArfNo"].count()>1).sum()
    pc   = int(df["is_peak"].sum())

    badges = [
        dbc.Badge(f"{len(df)} Members at BPS {bps_val}",color="info",    className="me-2 fs-6"),
        dbc.Badge(f"{pc} peaked here",                  color="primary",  className="me-2 fs-6"),
        dbc.Badge(f"{len(df)-pc} moved on",             color="secondary",className="me-2 fs-6"),
        dbc.Badge(f"{tc} tie group{'s'if tc!=1 else''}", color="warning"if tc else"success",className="me-2 fs-6"),
    ]
    df["label"] = df["Namee"]+"  (#"+df["seniority_rank"].astype(str)+")"
    f_bar = px.bar(df.sort_values("seniority_rank",ascending=False), x="seniority_rank", y="label",
        orientation="h", color="is_peak",
        color_discrete_map={True:P["gold"],False:P["teal"]},
        labels={"seniority_rank":"Overall Rank","label":"","is_peak":"Peak?"},
        text="seniority_rank",hover_data={"decision_basis":True,"qualification":True})
