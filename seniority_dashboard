# ─────────────────────────────────────────────────────────────────────────────
# GROUP CASCADE — walks an ENTIRE tied group through all 6 tiers at once,
# showing exactly which employees split away from which at every step.
# ─────────────────────────────────────────────────────────────────────────────
CASCADE_STEPS = [
    (1, "Peak BPS",                  "highest_bps"),
    (2, "Peak BPS Achievement Date", "bps_date_fmt"),
    (3, "Full Career Path",          "seniority_path_readable"),
    (4, "Government Entry Date",     "entry_fmt"),
    (5, "Date of Birth",             "dob_fmt"),
    (6, "ArfNo (final fallback)",    "ArfNo"),
]

def build_group_cascade(arf_list):
    """Given a list of ArfNos that started tied (same peak BPS + date), walk them
    through every tier, splitting the group at each step, until every member is
    uniquely resolved. Returns a list of step dicts for rendering."""
    df = report[report["ArfNo"].isin(arf_list)].sort_values("seniority_rank").copy()
    current_groups = [df]
    cascade = []
    for tier_no, title, field in CASCADE_STEPS:
        splits, still_tied = [], []
        for g in current_groups:
            for val, sub in g.groupby(field, sort=False):
                splits.append({"value": val, "members": sub.sort_values("seniority_rank"),
                               "resolved": len(sub) == 1})
                if len(sub) > 1:
                    still_tied.append(sub)
        cascade.append({"tier": tier_no, "title": title, "field": field, "splits": splits})
        current_groups = still_tied
        if not current_groups:
            break
    return cascade


