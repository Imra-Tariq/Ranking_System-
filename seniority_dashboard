        color_discrete_map={"Joining":"#3498DB","Reappointment":"#2ECC71","Promotion":"#F39C12"},
        labels={"event_date":"Date","Namee":""},title=f"BPS {bps_val} — Dates Reached",
        hover_data={"seniority_rank":True})
