def build_seniority_report(emp_csv, promo_csv, reapp_csv):
    emp   = pd.read_csv(emp_csv,   parse_dates=["DateOfBirth","dateofentryingov","DateOfJoining"])
    promo = pd.read_csv(promo_csv, parse_dates=["dateofpromotion"])
    reapp = pd.read_csv(reapp_csv, parse_dates=["dateofreappoitment"])
    combined = emp.merge(promo, on="ArfNo", how="left").merge(reapp, on="ArfNo", how="left")

    # all_bps_events
    def mk(df, date_col, bps_col, src, name_df=None):
        d = df[df[date_col].notna() & df[bps_col].notna()].copy()
        if name_df is not None:
            d = d.merge(name_df[["ArfNo","Namee"]], on="ArfNo", how="left")
        d = d[["ArfNo","Namee",date_col,bps_col]].copy()
        d.columns = ["ArfNo","Namee","event_date","bps_level"]
        d["source"] = src
        return d

    all_events = pd.concat([
        mk(emp,   "DateOfJoining",      "DateOfJoiningbps",      "Joining"),
        mk(reapp, "dateofreappoitment", "dateofreappoitmentbps", "Reappointment", emp),
        mk(promo, "dateofpromotion",    "dateofpromotionbps",    "Promotion",     emp),
    ], ignore_index=True)
    all_events["bps_level"] = all_events["bps_level"].astype(int)

    # bps_earliest
    bps_earliest = all_events.groupby(["ArfNo","bps_level"])["event_date"].min().reset_index()
    bps_earliest.rename(columns={"event_date":"achieved_date"}, inplace=True)

    # seniority_paths  (inverted-BPS + inverted-date countdown for correct DESC sort)
    FAR = pd.Timestamp("2099-12-31")

    def make_path(grp):
        g = grp.sort_values("bps_level", ascending=False)
        return "_".join(f"{100-int(r.bps_level):02d}-{(FAR-r.achieved_date).days:06d}"
                        for r in g.itertuples())

    paths    = bps_earliest.groupby("ArfNo")[["bps_level","achieved_date"]] \
                           .apply(make_path, include_groups=False).reset_index()
    paths.columns = ["ArfNo","seniority_path"]

    max_bps  = all_events.groupby("ArfNo")["bps_level"].max().reset_index(name="max_bps")
    peak_dt  = bps_earliest.merge(max_bps, on="ArfNo")
    peak_dt  = peak_dt[peak_dt["bps_level"]==peak_dt["max_bps"]] \
                       .groupby("ArfNo")["achieved_date"].min().reset_index(name="highest_bps_date")

    sp = paths.merge(max_bps.rename(columns={"max_bps":"highest_bps"}), on="ArfNo").merge(peak_dt, on="ArfNo")

    emp_base = combined.groupby("ArfNo").agg(
        Namee=("Namee","first"),
        dateofentryingov=("dateofentryingov","min"),
        DateOfBirth=("DateOfBirth","min")
    ).reset_index()

    tracking = sp.merge(emp_base, on="ArfNo")
    tracking["_pad"] = tracking["seniority_path"].apply(lambda p: p.ljust(500,"~"))
    sf = tracking.sort_values(["_pad","dateofentryingov","DateOfBirth","ArfNo"],
                              ascending=[False,True,True,True]).reset_index(drop=True)
    sf["seniority_rank"] = range(1, len(sf)+1)
    sf.drop(columns=["_pad"], inplace=True)

    # readable path
    def decode(path):
        parts = []
        for seg in path.split("_"):
            pp, cd = seg.split("-",1)
            parts.append(f"BPS-{100-int(pp)}: {(FAR-pd.Timedelta(days=int(cd))).strftime('%d-%b-%Y')}")
        return " → ".join(parts)
    sf["seniority_path_readable"] = sf["seniority_path"].apply(decode)

    # decision_basis
    bps_cnt  = sf.groupby("highest_bps")["ArfNo"].count().to_dict()
    path_ent = sf.groupby(["seniority_path","dateofentryingov"])["ArfNo"].count()
    path_dob = sf.groupby(["seniority_path","dateofentryingov","DateOfBirth"])["ArfNo"].count()

    def decide(row):
        segs = row["seniority_path"].split("_")
        bps  = row["highest_bps"]
        dfmt = lambda d: pd.to_datetime(d).strftime("%d-%b-%Y") if pd.notna(d) else "N/A"
        bd   = next((d for d in range(1,len(segs)+1)
                     if sf["seniority_path"].str.startswith("_".join(segs[:d])).sum()==1), None)
        if bd==1 and bps_cnt.get(bps,0)==1: return f"Unique at BPS {bps}"
        if bd==1: return f"Broke at L1 BPS {bps} date ({dfmt(row['highest_bps_date'])})"
        if bd is not None:
            seg=segs[bd-1]; sb=100-int(seg.split("-")[0])
            sd=(FAR-pd.Timedelta(days=int(seg.split("-",1)[1]))).strftime("%d-%b-%Y")
            return f"Broke at L{bd} BPS {sb} date ({sd})"
        if path_ent.get((row["seniority_path"],row["dateofentryingov"]),0)==1:
            return f"Broke by govt entry date ({dfmt(row['dateofentryingov'])})"
        if path_dob.get((row["seniority_path"],row["dateofentryingov"],row["DateOfBirth"]),0)==1:
            return f"Broke by date of birth ({dfmt(row['DateOfBirth'])})"
        return f"Broke by ArfNo ({row['ArfNo']})"

    sf["decision_basis"] = sf.apply(decide, axis=1)

    # ── STRUCTURED COMPARISON DATA (stored as JSON per employee) ─────────────
    # Each employee gets a list of tier dicts:
    #   {"tier":1, "title":"Same BPS 15", "field_value":"BPS 15",
    #    "resolved":False/True, "employees":[{"name","rank","detail"},…]}
    dfmt = lambda d: pd.Timestamp(d).strftime("%d-%b-%Y") if pd.notna(d) else "N/A"

    def build_comparison_json(row):
        arf   = row["ArfNo"]
        bps   = row["highest_bps"]
        bdate = row["highest_bps_date"]
        path  = row["seniority_path"]
        entry = row["dateofentryingov"]
        dob   = row["DateOfBirth"]
        tiers = []

        # Tier 1 — same peak BPS
        t1 = sf[(sf["highest_bps"]==bps) & (sf["ArfNo"]!=arf)]
        t1_emps = [{"name":r.Namee, "rank":int(r.seniority_rank),
                    "detail":f"BPS {r.highest_bps}  ·  reached {dfmt(r.highest_bps_date)}"}
                   for r in t1.sort_values("seniority_rank").itertuples()]
        resolved_t1 = t1.empty
        tiers.append({"tier":1, "title":f"Same Peak BPS {bps}",
                      "field_value":f"BPS {bps}", "resolved":resolved_t1,
                      "employees":t1_emps,
                      "note":"No one else reached this BPS level — unique." if resolved_t1
                             else f"{len(t1_emps)} employee(s) share this peak BPS level."})
        if resolved_t1:
            return json.dumps(tiers)

        # Tier 2 — same BPS + same peak date
        t2 = t1[t1["highest_bps_date"]==bdate]
        t2_emps = [{"name":r.Namee, "rank":int(r.seniority_rank),
                    "detail":f"BPS {r.highest_bps}  ·  {dfmt(r.highest_bps_date)}"}
                   for r in t2.sort_values("seniority_rank").itertuples()]
        resolved_t2 = t2.empty
        tiers.append({"tier":2, "title":f"Same BPS {bps} Achievement Date",
                      "field_value":dfmt(bdate), "resolved":resolved_t2,
                      "employees":t2_emps,
                      "note":f"Date {dfmt(bdate)} is unique within BPS {bps} group — rank resolved here."
                              if resolved_t2
                              else f"{len(t2_emps)} employee(s) also reached BPS {bps} on {dfmt(bdate)}."})
        if resolved_t2:
            return json.dumps(tiers)

        # Tier 3 — same full career path
        t3 = sf[(sf["seniority_path"]==path) & (sf["ArfNo"]!=arf)]
        t3_emps = [{"name":r.Namee, "rank":int(r.seniority_rank),
                    "detail":r.seniority_path_readable}
                   for r in t3.sort_values("seniority_rank").itertuples()]
        resolved_t3 = t3.empty
        tiers.append({"tier":3, "title":"Full Career Path (all BPS levels + dates)",
                      "field_value":"Entire path", "resolved":resolved_t3,
                      "employees":t3_emps,
                      "note":"Full career path is unique within the tied group — rank resolved here."
                              if resolved_t3
                              else f"{len(t3_emps)} employee(s) share an identical full career path."})
        if resolved_t3:
            return json.dumps(tiers)

        # Tier 4 — same path + entry date
        t4 = t3[t3["dateofentryingov"]==entry]
        t4_emps = [{"name":r.Namee, "rank":int(r.seniority_rank),
                    "detail":f"Govt entry: {dfmt(r.dateofentryingov)}"}
                   for r in t4.sort_values("seniority_rank").itertuples()]
        resolved_t4 = t4.empty
        tiers.append({"tier":4, "title":"Government Entry Date",
                      "field_value":dfmt(entry), "resolved":resolved_t4,
                      "employees":t4_emps,
                      "note":f"Entry date {dfmt(entry)} is unique within the group — rank resolved here."
                              if resolved_t4
                              else f"{len(t4_emps)} employee(s) also entered government on {dfmt(entry)}."})
        if resolved_t4:
            return json.dumps(tiers)

        # Tier 5 — same path + entry + DOB
        t5 = t4[t4["DateOfBirth"]==dob]
        t5_emps = [{"name":r.Namee, "rank":int(r.seniority_rank),
                    "detail":f"DOB: {dfmt(r.DateOfBirth)}"}
                   for r in t5.sort_values("seniority_rank").itertuples()]
        resolved_t5 = t5.empty
        tiers.append({"tier":5, "title":"Date of Birth",
                      "field_value":dfmt(dob), "resolved":resolved_t5,
                      "employees":t5_emps,
                      "note":f"Date of birth {dfmt(dob)} is unique — rank resolved here."
                              if resolved_t5
                              else f"{len(t5_emps)} employee(s) also born on {dfmt(dob)}."})
        if resolved_t5:
            return json.dumps(tiers)

        # Tier 6 — ArfNo
        tiers.append({"tier":6, "title":"ArfNo (absolute fallback)",
                      "field_value":str(arf), "resolved":True,
                      "employees":[],
                      "note":f"All fields identical. Smallest ArfNo wins — this employee's ArfNo is {arf}."})
        return json.dumps(tiers)

    sf["comparison_json"] = sf.apply(build_comparison_json, axis=1)
    sf["tied_group_size"] = sf.groupby(["highest_bps","highest_bps_date"])["ArfNo"].transform("count")

    def tier_label(d):
        if "Unique at BPS"  in d: return "Tier 1 – Unique BPS"
        if "Broke at L1"    in d: return "Tier 2 – BPS Date"
        if "Broke at L"     in d: return "Tier 3 – Career Depth"
        if "entry date"     in d: return "Tier 4 – Govt Entry"
        if "date of birth"  in d: return "Tier 5 – DOB"
        return "Tier 6 – ArfNo"
    sf["tier_label"] = sf["decision_basis"].apply(tier_label)

    sf = sf.merge(emp[["ArfNo","Trade","qualification"]], on="ArfNo", how="left")
    return sf, all_events, emp, promo, reapp


