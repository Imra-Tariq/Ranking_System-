    ("Date of Birth",    lambda r: r.dob_fmt,                "dob_fmt"),
    ("ArfNo",            lambda r: str(r.ArfNo),             "ArfNo"),
]

def render_group_table(members_df, active_field=None):
    """Side-by-side comparison: one COLUMN per employee, one ROW per attribute
    (qualification, peak BPS, full BPS history, entry date, DOB, ArfNo).
    The row matching `active_field` is highlighted gold; within that row, cells
    that still match another employee turn amber ('🔗 still tied'), cells that
    are unique in the group turn green ('✅ splits off') — so you can see, at a
    glance, exactly which employees are being compared and on what value."""
    people = list(members_df.itertuples())
    header = html.Tr(
        [html.Th("Attribute", style={"color": P["muted"], "padding": "6px 10px",
                                      "background": P["slate"], "textAlign": "left",
                                      "fontSize": "0.72rem", "textTransform": "uppercase"})] +
        [html.Th([html.Div(f"#{p.seniority_rank}  ·  ArfNo {p.ArfNo}",
                            style={"color": P["teal"], "fontWeight": "800", "fontSize": "0.72rem"}),
                  html.Div(p.Namee, style={"color": P["text"], "fontWeight": "700", "fontSize": "0.88rem"})],
                 style={"padding": "6px 10px", "background": P["slate"], "textAlign": "left"})
         for p in people]
    )
    body_rows = []
    for label, getter, field in COMPARISON_ROWS:
        raw_vals = [getter(p) for p in people]
        is_active = field is not None and field == active_field
        dup_ok = all(isinstance(v, str) for v in raw_vals)   # only plain strings are diffable inline
        counts = {}
        if dup_ok:
            for v in raw_vals:
                counts[v] = counts.get(v, 0) + 1
        cells = [html.Td(label, style={"color": P["muted"], "fontWeight": "700", "padding": "6px 10px",
                                        "fontSize": "0.8rem", "whiteSpace": "nowrap",
                                        "borderTop": f"2px solid {P['gold']}" if is_active else "none"})]
        for v in raw_vals:
            marker, bg, bd = None, "transparent", P["border"]
            if is_active and dup_ok:
                shared = counts[v] > 1
                bg = "#E74C3C22" if shared else "#2ECC7122"
                bd = "#E74C3C" if shared else "#2ECC71"
                marker = "🔗 still tied" if shared else "✅ splits off here"
            cells.append(html.Td([
                v,
                html.Div(marker, style={"fontSize": "0.68rem", "color": bd, "fontWeight": "700",
                                         "marginTop": "3px"}) if marker else None,
            ], style={"padding": "6px 10px", "fontSize": "0.82rem", "color": P["text"], "background": bg,
                       "border": f"1px solid {bd}" if is_active else "1px solid transparent",
                       "borderTop": f"2px solid {P['gold']}" if is_active else "none",
                       "verticalAlign": "top"}))
        body_rows.append(html.Tr(cells, style={"borderBottom": f"1px solid {P['border']}"}))
    return html.Table([html.Thead(header), html.Tbody(body_rows)],
                       style={"width": "100%", "borderCollapse": "collapse", "marginBottom": "16px"})


def render_cascade(cascade, header_label=""):
    """Walk the tiers: for every still-tied cluster entering a tier, show a full
    side-by-side comparison table (who's being compared, on what data) with the
    deciding row highlighted, then whoever splits off is marked resolved and
    whoever remains tied carries on into the next tier's table."""
    blocks = []
    if header_label:
        blocks.append(html.H6(header_label, style={"color": P["gold"], "fontWeight": "700",
                                                     "marginBottom": "10px"}))
    for step in cascade:
        tc = TIER_COLORS.get(step["tier"], P["muted"])
        clusters     = [s["members"] for s in step["splits"] if len(s["members"]) > 1]
        resolved_now = [s["members"] for s in step["splits"] if len(s["members"]) == 1]

        card_body = []
        if clusters:
            for cl in clusters:
                card_body.append(html.Div(
                    f"Comparing {len(cl)} employees still tied going into this tier:",
                    style={"color": P["muted"], "fontSize": "0.82rem", "marginBottom": "6px"}))
                card_body.append(render_group_table(cl, active_field=step["field"]))

        if resolved_now:
            names = ", ".join(f"{f.iloc[0]['Namee']} (#{int(f.iloc[0]['seniority_rank'])})" for f in resolved_now)
            card_body.append(html.Div([
                html.I(className="fas fa-check-circle me-2", style={"color": "#2ECC71"}),
                html.Span(f"Resolved at this tier: {names}", style={"color": "#2ECC71", "fontSize": "0.82rem"}),
            ], style={"marginTop": "4px", "marginBottom": "4px"}))

        card = dbc.Card([
            dbc.CardHeader([
                html.I(className=f"fas fa-{TIER_ICONS.get(step['tier'], 'circle')} me-2", style={"color": tc}),
                html.Span(f"Tier {step['tier']}", style={"color": tc, "fontWeight": "800", "marginRight": "8px"}),
                html.Span(step["title"], style={"color": P["text"], "fontWeight": "600"}),
            ], style={"background": tc + "22", "borderBottom": f"1px solid {tc}"}),
            dbc.CardBody(card_body if card_body else
                         html.Div("Nothing left to compare — fully resolved above.",
                                  style={"color": P["muted"], "fontStyle": "italic", "fontSize": "0.82rem"})),
        ], style={"background": P["card"], "border": f"1px solid {P['border']}", "marginBottom": "10px"})
        blocks.append(card)

        if not clusters:
            blocks.append(html.Div([
                html.I(className="fas fa-flag-checkered me-2", style={"color": "#2ECC71"}),
                html.Span("Every employee in this group is fully resolved.",
                          style={"color": "#2ECC71", "fontWeight": "600"}),
            ], className="mb-3"))
            break
    return html.Div(blocks)


