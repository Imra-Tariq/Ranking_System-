COMPARISON_ROWS = [
    ("Qualification",    lambda r: r.qualification,        None),
    ("Peak BPS",         lambda r: f"BPS {r.highest_bps}",  "highest_bps"),
    ("Peak BPS Date",    lambda r: r.bps_date_fmt,          "bps_date_fmt"),
