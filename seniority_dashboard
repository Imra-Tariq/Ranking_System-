        items.append(dbc.AccordionItem(body, item_id=f"bps-{bv}",
            title=f"BPS {bv}  ·  {len(df)} employees  ·  {int(df['is_peak'].sum())} peaked  ·  {len(tg)} tie group(s)"))
    return items

